# === 敏感信息 ===
LLM_API_KEY=sk-your-api-key-here
EMBEDDING_API_KEY=                    # 留空则与 LLM_API_KEY 相同
RERANKER_API_KEY=                     # 留空则与 LLM_API_KEY 相同

# === LLM 大模型配置 ===
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# === Embedding 向量模型配置 ===
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096

# === Reranker 重排序配置（可选） ===
RERANKER_ENABLED=false
RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=5

# === 日志配置 ===
LOG_LEVEL=INFO
LOG_FILE=logs/kb.log

# === 搜索配置 ===
DEFAULT_TOP_K=5
SIMILARITY_MERGE_THRESHOLD=0.85
RELATED_THRESHOLD=0.8
CONTENT_DUPLICATE_THRESHOLD=0.95
